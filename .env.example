# Anthropic API Key (required)
ANTHROPIC_API_KEY=your-api-key-here

# ============================================
# Discord Bot Configuration
# ============================================

# REQUIRED: Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# OPTIONAL: Behavior settings
# Note: These override config/default.json if set
# Tip: Configure these in config/default.json instead for easier management

# Require @mention to respond in channels (true/false)
# DISCORD_REQUIRE_MENTION=true

# Whitelist specific channels (comma-separated Discord channel IDs)
# Leave unset or empty to allow all channels
# Get IDs: Enable Developer Mode in Discord, right-click channel → Copy ID
# DISCORD_ALLOWED_CHANNELS=1234567890123456789,9876543210987654321

# Whitelist specific users (comma-separated Discord user IDs)
# Leave unset or empty to allow all users
# Get IDs: Right-click username → Copy ID
# DISCORD_ALLOWED_USERS=1234567890123456789,9876543210987654321

# ============================================
# Multi-account Discord (Advanced)
# ============================================
# Run multiple Discord bots simultaneously
# Uncomment and configure if you need multiple bot accounts:

# DISCORD_ACCOUNTS=bot1,bot2
# DISCORD_BOT1_TOKEN=first-bot-token
# DISCORD_BOT1_REQUIRE_MENTION=true
# DISCORD_BOT1_ALLOWED_CHANNELS=1234567890123456789
# DISCORD_BOT2_TOKEN=second-bot-token
# DISCORD_BOT2_REQUIRE_MENTION=false
# DISCORD_BOT2_ALLOWED_CHANNELS=9876543210987654321
